# Actor runtime red-label attract title script.
# Format: <action> <start-step> <duration|forever> <x> <y> [text]
# message uses: <label> <top-left-screen-address>
# high_scores adds: <row-height> <rows>
# credits and credits_nonzero use: <label-x> <label-y> <count-x> <count-y>

williams_logo 1 forever 108 60
